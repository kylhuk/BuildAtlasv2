# Example environment variables used by the Vite UI build
# Copy this file to .env.development.local (or .env) to load during dev
# Only VITE_ prefixed variables are exposed to the frontend per Vite rules
VITE_API_BASE_URL=http://localhost:8000
# Legacy alias still supported for older setups
# VITE_BACKEND_URL=http://localhost:8000
VITE_API_TIMEOUT_MS=5000
VITE_APP_TITLE=BuildAtlas UI
